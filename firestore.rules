rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: locations
    // Fields:
    //   - name: string (required)
    //
    // Collection: slots
    // Fields:
    //   - location_id: string (required)
    //   - date: string (required, YYYY-MM-DD)
    //   - time: string (required, HH:MM)
    //   - is_available: bool (required)
    //
    // Collection: bookings
    // Fields:
    //   - slot_id: string (required)
    //   - student_name: string (required)
    //   - student_phone: string (required)
    //   - booking_type: string (required)
    //   - price: number (required)
    //   - paid: bool (required)
    //   - date: string (required)
    //   - time: string (required)
    //   - location_name: string (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "uillian.bedinoto@gmail.com");
    }

    function isValidLocation(data) {
      return data.keys().hasAll(['name']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100;
    }

    function isValidSlot(data) {
      return data.keys().hasAll(['location_id', 'date', 'time', 'is_available']) &&
             data.location_id is string &&
             data.date is string && data.date.matches("^\\d{4}-\\d{2}-\\d{2}$") &&
             data.time is string && data.time.matches("^\\d{2}:\\d{2}$") &&
             data.is_available is bool;
    }

    function isValidBooking(data) {
      return data.keys().hasAll(['slot_id', 'student_name', 'student_phone', 'booking_type', 'price', 'paid', 'date', 'time', 'location_name']) &&
             data.slot_id is string &&
             data.student_name is string && data.student_name.size() > 0 && data.student_name.size() < 100 &&
             data.student_phone is string && data.student_phone.size() > 0 && data.student_phone.size() < 30 &&
             data.booking_type is string &&
             data.price is number &&
             data.paid is bool &&
             data.date is string &&
             data.time is string &&
             data.location_name is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /locations/{locationId} {
      allow read: if true; // Public read for booking
      allow write: if isAdmin() && isValidLocation(request.resource.data);
    }

    match /slots/{slotId} {
      allow read: if true; // Public read for booking
      allow create: if isAdmin() && isValidSlot(request.resource.data);
      allow update: if (isAdmin() && isValidSlot(request.resource.data)) || 
                     (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['is_available']) && 
                      request.resource.data.is_available == false); // Allow public to mark as unavailable when booking
      allow delete: if isAdmin();
    }

    match /bookings/{bookingId} {
      allow read: if isAdmin();
      allow create: if isValidBooking(request.resource.data); // Public can create booking
      allow update, delete: if isAdmin();
    }
    
    match /test/connection {
      allow read: if true;
    }

    match /settings/google_calendar {
      allow read, write: if true;
    }

    match /settings/{settingId} {
      allow read, write: if isAdmin();
    }
  }
}
